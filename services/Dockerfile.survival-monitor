# AstroJOE Survival Monitor — Docker build
# Usage: docker compose up -d survival-monitor

FROM node:20-slim

WORKDIR /app

COPY package.json package-lock.json* ./
RUN npm ci --omit=dev 2>/dev/null || npm install --omit=dev

COPY services/survival-monitor.ts ./
COPY tsconfig.json ./

RUN npm install -g ts-node typescript

ENV NODE_ENV=production

CMD ["ts-node", "survival-monitor.ts"]
