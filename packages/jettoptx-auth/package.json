{
  "name": "@jettoptx/auth",
  "version": "0.1.0",
  "description": "JettChat Auth SDK: X OAuth 2.0 PKCE + Solana signMessage + Ed25519 JWT",
  "license": "MIT",
  "main": "index.js",
  "module": "index.mjs",
  "types": "index.d.ts",
  "exports": {
    ".": {
      "import": "./index.mjs",
      "require": "./index.js",
      "types": "./index.d.ts"
    },
    "./next": {
      "import": "./next/index.mjs",
      "require": "./next/index.js",
      "types": "./next/index.d.ts"
    },
    "./api": {
      "import": "./api/index.mjs",
      "require": "./api/index.js",
      "types": "./api/index.d.ts"
    }
  },
  "dependencies": {
    "tweetnacl": "^1.0.3",
    "tweetnacl-util": "^0.15.1"
  },
  "peerDependencies": {
    "next": ">=14.0.0",
    "react": ">=18.0.0",
    "@solana/web3.js": ">=1.90.0",
    "@solana/wallet-adapter-react": ">=0.15.0"
  },
  "peerDependenciesMeta": {
    "next": { "optional": true },
    "react": { "optional": true },
    "@solana/web3.js": { "optional": true },
    "@solana/wallet-adapter-react": { "optional": true }
  },
  "devDependencies": {
    "typescript": "^5.4.0",
    "tsup": "^8.0.0",
    "vitest": "^1.6.0",
    "@types/node": "^20.0.0",
    "@types/react": "^18.0.0",
    "next": "^14.2.0",
    "react": "^18.3.0",
    "@solana/web3.js": "^1.95.0",
    "@solana/wallet-adapter-react": "^0.15.0"
  }
}
